# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/statbooks?appName=<app-name>


# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Google Books API
GOOGLE_BOOKS_API_KEY=

# Google Sign-In (OAuth). Create credentials at
# https://console.cloud.google.com/apis/credentials (Web client).
# The same client ID goes into the frontend as VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=
# Optional for future server-side OAuth flows.
GOOGLE_CLIENT_SECRET=

# Affiliate: Amazon Associates tracking tag appended to outbound links.
AMAZON_ASSOC_TAG=

# Claude AI (optional - used by recommend/context/mood-search)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# OpenRouter (free models) - powers the floating book chat assistant.
# Get a key at https://openrouter.ai/keys . Pick any free model below.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free
# Optional split keys/models:
# - Search pipeline (book finding, preview generation)
OPENROUTER_SEARCH_API_KEY=
OPENROUTER_SEARCH_MODEL=google/gemini-2.5-flash
# - Floating chat assistant
OPENROUTER_CHAT_API_KEY=
OPENROUTER_CHAT_MODEL=openai/gpt-4.1-mini

# Payme
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
PAYME_TEST_SECRET_KEY=

# Click
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# AWS S3 (for book covers)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=

# Email (verification codes). Get a key at https://resend.com .
# Without a key, codes are printed to the server console (dev only).
RESEND_API_KEY=
EMAIL_FROM=StatBooks <onboarding@resend.dev>
# Keep false to avoid printing verification codes in terminal logs.
ALLOW_EMAIL_DEV_FALLBACK=false
# Optional test inbox: force all verification codes to this email while testing.
AUTH_CODE_TEST_INBOX=

# Optional SMS provider (login alerts). Configure your provider webhook.
# The backend will POST JSON {to, message, from} by default.
SMS_API_URL=
SMS_API_KEY=
SMS_API_KEY_HEADER=authorization
SMS_API_KEY_PREFIX=Bearer 
SMS_TO_FIELD=to
SMS_MESSAGE_FIELD=message
SMS_FROM_FIELD=from
SMS_FROM=StatBooks
