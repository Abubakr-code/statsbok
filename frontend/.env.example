# Base URL for API calls. Default "/api" works with the Vite dev proxy
# and with nginx in production. Set to a full URL only for split deploys.
VITE_API_URL=/api

# Dev-only: where the Vite proxy forwards /api during `npm run dev`.
VITE_BACKEND_URL=https://statbooks.onrender.com

# Payment provider redirect identifiers (public, safe to expose).
# Leave empty until you have merchant accounts.
VITE_PAYME_MERCHANT_ID=
VITE_CLICK_SERVICE_ID=
VITE_CLICK_MERCHANT_ID=

# Google Sign-In client ID (same as backend GOOGLE_CLIENT_ID). When empty,
# the Google button shows as a disabled placeholder.
VITE_GOOGLE_CLIENT_ID=
